{
  "meta": {
    "title": "Flying Car v1",
    "description": "Jetsons/Fifth-Element style hover car. First generation \u2014 intentionally noisy. Ripple and inrush spikes are gameplay hazards the player mitigates through upgrades and wiring corrections.",
    "challenges": [
      {
        "id": "avionics_brownout",
        "title": "Avionics Brownout on Motor Startup",
        "description": "The 48V Avionics Converter (node 19) uses a proportional turns-ratio model. When the 4 lift motors start simultaneously they produce ~190% inrush on the Motor Bus (node 4), dragging the HV Bus (node 3) below ~190V. The converter output drops to ~38V \u2014 below the Flight Computer's minVolts:40 \u2014 causing a reboot mid-startup.",
        "symptoms": [
          "Flight Computer reboots during lift motor startup",
          "Navigation and Comms go dark briefly",
          "Stability Control Unit disconnects"
        ],
        "solutions": [
          {
            "tier": 1,
            "label": "Stagger Motor Startup",
            "description": "Start lift motors in sequence (FL \u2192 FR \u2192 RL \u2192 RR) with 500ms gaps so inrush spikes do not overlap. Cheap, no new parts, but fragile \u2014 a single rough landing still causes simultaneous restart.",
            "type": "procedure"
          },
          {
            "tier": 2,
            "label": "Isolate Avionics to Dedicated Generator",
            "description": "Disconnect the Avionics Converter from the shared HV Bus and feed it from a small, clean, dedicated power cell. Avionics are now fully isolated from motor noise. This is the recommended Tier-2 upgrade.",
            "type": "rewire",
            "scenario": "avionics-isolation"
          },
          {
            "tier": 3,
            "label": "Install Motor Bus Breaker",
            "description": "Insert a breaker between HV Bus and Motor Bus rated just above normal motor draw. Motor trips are isolated from the avionics rail, but doesn't prevent brownout during healthy inrush.",
            "type": "rewire"
          },
          {
            "tier": 4,
            "label": "Upgrade to Regulated Converter",
            "description": "Replace the proportional Avionics Converter with a regulated model that holds outVolts fixed regardless of input sag. Any input above ~55V produces a stable 48V output.",
            "type": "component_upgrade"
          }
        ]
      },
      {
        "id": "running_light_blowouts",
        "title": "Running Lights Blow on Startup",
        "description": "The 4 corner running lights (nodes 34\u201337) have maxVolts 255\u2013263V on a 240V bus with \u00b128V ripple. Startup spikes routinely push voltage past their threshold, blowing them.",
        "symptoms": [
          "Running lights go dark within seconds of startup",
          "Fog lights occasionally blow"
        ],
        "solutions": [
          {
            "tier": 1,
            "label": "Swap to Hardened Bulbs",
            "description": "Replace running lights with units rated to maxVolts 310V \u2014 the same tolerance as the headlights. Simple component swap.",
            "type": "component_upgrade"
          },
          {
            "tier": 2,
            "label": "Install Lighting Surge Suppressor",
            "description": "Insert a converter on the Lighting Bus set to outVolts 230V with a tight efficiency. Clips peaks before they reach the bulbs.",
            "type": "rewire"
          }
        ]
      }
    ]
  },
